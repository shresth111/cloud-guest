CLOUDGUEST_ENVIRONMENT=local
CLOUDGUEST_DEBUG=true
CLOUDGUEST_SERVICE_NAME=cloudguest-backend
CLOUDGUEST_API_V1_PREFIX=/api/v1
CLOUDGUEST_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CLOUDGUEST_DATABASE_URL=postgresql+asyncpg://cloudguest:cloudguest@postgres:5432/cloudguest
CLOUDGUEST_DATABASE_POOL_SIZE=10
CLOUDGUEST_DATABASE_MAX_OVERFLOW=20
CLOUDGUEST_DATABASE_POOL_TIMEOUT=30
CLOUDGUEST_REDIS_URL=redis://redis:6379/0
CLOUDGUEST_REDIS_HEALTH_TIMEOUT_SECONDS=2
CLOUDGUEST_LOG_LEVEL=INFO
CLOUDGUEST_LOG_DIR=/var/log/cloudguest
CLOUDGUEST_LOG_FILE=cloudguest.log
CLOUDGUEST_LOG_MAX_BYTES=10485760
CLOUDGUEST_LOG_BACKUP_COUNT=10
CLOUDGUEST_REQUEST_TIMEOUT_SECONDS=30

