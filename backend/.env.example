# CloudGuest backend environment configuration.
#
# Generated from app/core/config.py::Settings -- every field there has an
# entry here. Values marked "MUST override outside local" are either
# security-sensitive (secrets/keys) or environment-specific and must be
# replaced with real values in any non-local deployment; every other value
# is a safe, working default suitable for local development as-is.

# ==============================================================================
# Core application
# ==============================================================================
CLOUDGUEST_ENVIRONMENT=local
CLOUDGUEST_DEBUG=true
CLOUDGUEST_SERVICE_NAME=cloudguest-backend
CLOUDGUEST_API_V1_PREFIX=/api/v1
CLOUDGUEST_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================
CLOUDGUEST_DATABASE_URL=postgresql+asyncpg://cloudguest:cloudguest@postgres:5432/cloudguest
CLOUDGUEST_DATABASE_POOL_SIZE=10
CLOUDGUEST_DATABASE_MAX_OVERFLOW=20
CLOUDGUEST_DATABASE_POOL_TIMEOUT=30

# ==============================================================================
# Redis
# ==============================================================================
CLOUDGUEST_REDIS_URL=redis://redis:6379/0
CLOUDGUEST_REDIS_HEALTH_TIMEOUT_SECONDS=2

# ==============================================================================
# Logging
# ==============================================================================
CLOUDGUEST_LOG_LEVEL=INFO
CLOUDGUEST_LOG_DIR=/var/log/cloudguest
CLOUDGUEST_LOG_FILE=cloudguest.log
CLOUDGUEST_LOG_MAX_BYTES=10485760
CLOUDGUEST_LOG_BACKUP_COUNT=10

# ==============================================================================
# HTTP
# ==============================================================================
CLOUDGUEST_REQUEST_TIMEOUT_SECONDS=30

# ==============================================================================
# Auth / JWT
# ==============================================================================
# MUST override outside local -- sign every issued JWT. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
CLOUDGUEST_JWT_SECRET_KEY=insecure-local-dev-secret-key-change-me-32chars
CLOUDGUEST_JWT_ALGORITHM=HS256
CLOUDGUEST_ACCESS_TOKEN_EXPIRE_MINUTES=15
CLOUDGUEST_REFRESH_TOKEN_EXPIRE_DAYS=7
CLOUDGUEST_MAX_LOGIN_ATTEMPTS=5
CLOUDGUEST_ACCOUNT_LOCKOUT_MINUTES=30
CLOUDGUEST_PASSWORD_HISTORY_LIMIT=5

# ==============================================================================
# RBAC
# ==============================================================================
CLOUDGUEST_RBAC_PERMISSION_CACHE_TTL_SECONDS=300
CLOUDGUEST_RBAC_MAX_PARENT_ROLE_DEPTH=10

# ==============================================================================
# Router (RouterOS API credential encryption + provisioning + WireGuard)
# ==============================================================================
# MUST override outside local -- encrypts RouterOS API credentials at rest.
# Generate a real Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CLOUDGUEST_ROUTER_ENCRYPTION_KEY=aW5zZWN1cmUtbG9jYWwtZGV2LWZlcm5ldC1rZXkzMiE=
CLOUDGUEST_ROUTER_PROVISIONING_TOKEN_EXPIRE_HOURS=24
CLOUDGUEST_WIREGUARD_HANDSHAKE_STALE_AFTER_MINUTES=5

# ==============================================================================
# OTP
# ==============================================================================
CLOUDGUEST_OTP_CODE_LENGTH=6
CLOUDGUEST_OTP_EXPIRY_SECONDS=300
CLOUDGUEST_OTP_MAX_VERIFICATION_ATTEMPTS=5
CLOUDGUEST_OTP_MAX_REQUESTS_PER_WINDOW=5
CLOUDGUEST_OTP_REQUEST_WINDOW_MINUTES=60

# ==============================================================================
# Analytics -- Forecast Engine
# ==============================================================================
CLOUDGUEST_ANALYTICS_FORECAST_HISTORY_DAYS=30
CLOUDGUEST_ANALYTICS_FORECAST_DEFAULT_DAYS=7
CLOUDGUEST_ANALYTICS_FORECAST_MIN_HISTORY_POINTS=3
CLOUDGUEST_ANALYTICS_FORECAST_CAPACITY_ROUTER_COUNT_THRESHOLD=50
CLOUDGUEST_ANALYTICS_FORECAST_ROUTER_HEALTH_LOOKBACK_DAYS=14
CLOUDGUEST_ANALYTICS_FORECAST_ROUTER_CPU_RISING_SLOPE_THRESHOLD=1.0
CLOUDGUEST_ANALYTICS_FORECAST_ROUTER_MEMORY_RISING_SLOPE_THRESHOLD=1.0
CLOUDGUEST_ANALYTICS_FORECAST_ROUTER_UNHEALTHY_RATIO_THRESHOLD=0.3
CLOUDGUEST_ANALYTICS_FORECAST_ROUTER_ALERT_COUNT_THRESHOLD=2
CLOUDGUEST_ANALYTICS_FORECAST_ROUTER_ALERT_LOOKBACK_DAYS=7

# ==============================================================================
# Analytics -- Business Insight Engine
# ==============================================================================
CLOUDGUEST_ANALYTICS_INSIGHT_CUSTOMER_GROWTH_SIGNIFICANT_PERCENT=10.0
CLOUDGUEST_ANALYTICS_INSIGHT_GUEST_GROWTH_SIGNIFICANT_PERCENT=15.0
CLOUDGUEST_ANALYTICS_INSIGHT_PLAN_DISTRIBUTION_MIN_COVERAGE_PERCENT=50.0
CLOUDGUEST_ANALYTICS_INSIGHT_OFFLINE_ROUTER_HOURS_THRESHOLD=24
CLOUDGUEST_ANALYTICS_INSIGHT_OFFLINE_ROUTER_COUNT_THRESHOLD=1
CLOUDGUEST_ANALYTICS_INSIGHT_OFFLINE_ROUTER_CRITICAL_COUNT_THRESHOLD=3
CLOUDGUEST_ANALYTICS_INSIGHT_LOCATION_VOLUME_LOOKBACK_DAYS=7
CLOUDGUEST_ANALYTICS_INSIGHT_LOCATION_VOLUME_DROP_PERCENT=20.0
CLOUDGUEST_ANALYTICS_INSIGHT_ROUTER_CPU_LOOKBACK_DAYS=7
CLOUDGUEST_ANALYTICS_INSIGHT_ROUTER_CPU_CONSECUTIVE_THRESHOLD=3
CLOUDGUEST_ANALYTICS_INSIGHT_CRITICAL_ALERT_COUNT_THRESHOLD=2
CLOUDGUEST_ANALYTICS_INSIGHT_CRITICAL_ALERT_AGE_HOURS_THRESHOLD=24

# ==============================================================================
# Billing -- Subscription + Renewal + Coupon Engines
# ==============================================================================
CLOUDGUEST_SUBSCRIPTION_TRIAL_PERIOD_DAYS=14
CLOUDGUEST_SUBSCRIPTION_RENEWAL_GRACE_PERIOD_DAYS=7
CLOUDGUEST_SUBSCRIPTION_RENEWAL_REMINDER_DAYS_BEFORE=3
CLOUDGUEST_SUBSCRIPTION_EXPIRY_REMINDER_DAYS_BEFORE=3

# ==============================================================================
# Billing -- Payment gateways (Stripe / Razorpay)
# ==============================================================================
# Empty = unconfigured, the honest default: PaymentGatewayNotConfiguredError
# is raised for any real charge attempt instead of a network call or a
# fabricated success. MUST override outside local with real provider
# credentials.
CLOUDGUEST_STRIPE_SECRET_KEY=
CLOUDGUEST_STRIPE_WEBHOOK_SECRET=
CLOUDGUEST_STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
CLOUDGUEST_RAZORPAY_KEY_ID=
CLOUDGUEST_RAZORPAY_KEY_SECRET=
CLOUDGUEST_RAZORPAY_WEBHOOK_SECRET=
CLOUDGUEST_PAYMENT_DEFAULT_PROVIDER=stripe
CLOUDGUEST_PAYMENT_WEBHOOK_EVENT_DEDUP_TTL_SECONDS=604800

# ==============================================================================
# Billing -- Invoice Engine + Tax/GST
# ==============================================================================
CLOUDGUEST_PLATFORM_GST_STATE=Maharashtra
CLOUDGUEST_PLATFORM_GST_COUNTRY=IN
# Empty = unconfigured, an honest cosmetic-only gap (invoice PDFs still
# generate, just without a seller GSTIN line). MUST override outside local
# with the platform's real GSTIN.
CLOUDGUEST_PLATFORM_GSTIN=
CLOUDGUEST_PLATFORM_LEGAL_BUSINESS_NAME=CloudGuest
CLOUDGUEST_INVOICE_DUE_DAYS=15
CLOUDGUEST_INVOICE_OVERDUE_SWEEP_INTERVAL_SECONDS=3600.0

# ==============================================================================
# Observability -- OpenTelemetry
# ==============================================================================
# Unset = spans still generated by a real OpenTelemetry SDK TracerProvider,
# exported to the console instead of a network collector -- the honest
# default when no real Collector/Jaeger/Tempo instance exists. Set to a real
# collector's OTLP/HTTP endpoint outside local, e.g.:
#   CLOUDGUEST_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
CLOUDGUEST_OTEL_EXPORTER_OTLP_ENDPOINT=

# ==============================================================================
# Notification -- real email/SMS providers
# ==============================================================================
# "logging" (default) keeps today's log-only behavior with zero config.
# Set to "smtp"/"ses" (email) or "twilio" (SMS) plus the matching
# credentials below to send for real. MUST override outside local if you
# select a real provider.
CLOUDGUEST_EMAIL_DELIVERY_PROVIDER=logging
CLOUDGUEST_SMTP_HOST=
CLOUDGUEST_SMTP_PORT=587
CLOUDGUEST_SMTP_USERNAME=
CLOUDGUEST_SMTP_PASSWORD=
CLOUDGUEST_SMTP_USE_TLS=true
CLOUDGUEST_SMTP_FROM_ADDRESS=noreply@cloudguest.local
CLOUDGUEST_SES_ACCESS_KEY_ID=
CLOUDGUEST_SES_SECRET_ACCESS_KEY=
CLOUDGUEST_SES_REGION=us-east-1
CLOUDGUEST_SES_FROM_ADDRESS=
CLOUDGUEST_SMS_DELIVERY_PROVIDER=logging
CLOUDGUEST_TWILIO_ACCOUNT_SID=
CLOUDGUEST_TWILIO_AUTH_TOKEN=
CLOUDGUEST_TWILIO_FROM_NUMBER=

# ==============================================================================
# Object storage (S3-compatible -- MinIO in docker-compose locally)
# ==============================================================================
CLOUDGUEST_S3_ENDPOINT_URL=http://minio:9000
CLOUDGUEST_S3_BUCKET_NAME=cloudguest
CLOUDGUEST_S3_ACCESS_KEY_ID=cloudguest
CLOUDGUEST_S3_SECRET_ACCESS_KEY=cloudguest12345
CLOUDGUEST_S3_REGION=us-east-1

# ==============================================================================
# Notification -- dispatch outbox
# ==============================================================================
CLOUDGUEST_NOTIFICATION_DISPATCH_SWEEP_INTERVAL_SECONDS=60.0
CLOUDGUEST_NOTIFICATION_MAX_DELIVERY_ATTEMPTS=5
CLOUDGUEST_NOTIFICATION_RETRY_BACKOFF_SECONDS=300

# ==============================================================================
# Security surface -- MFA/TOTP
# ==============================================================================
# MUST override outside local -- encrypts TOTP secrets at rest. Generate
# with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CLOUDGUEST_MFA_ENCRYPTION_KEY=aW5zZWN1cmUtbG9jYWwtZGV2LWZlcm5ldC1rZXkzMiE=
CLOUDGUEST_MFA_RECOVERY_CODE_COUNT=10

# ==============================================================================
# Security surface -- rate limiting
# ==============================================================================
CLOUDGUEST_RATE_LIMIT_MAX_REQUESTS=60
CLOUDGUEST_RATE_LIMIT_WINDOW_SECONDS=60
