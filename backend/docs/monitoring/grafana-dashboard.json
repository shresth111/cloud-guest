{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "The Prometheus data source scraping this app's GET /metrics endpoint (see docs/monitoring/OBSERVABILITY.md).",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "id": null,
  "uid": "cloudguest-observability",
  "title": "CloudGuest Backend Observability",
  "description": "HTTP-level and business metrics exposed by the CloudGuest backend's GET /metrics endpoint (app.core.metrics). Every panel below references only metric names genuinely defined there -- see docs/monitoring/OBSERVABILITY.md.",
  "tags": ["cloudguest", "observability", "be-011"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "label": "Prometheus",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Request Rate (by status code)",
      "description": "sum(rate(cloudguest_http_requests_total[5m])) by (status_code) -- PrometheusMiddleware (app.core.metrics) increments this Counter inline, once per completed request.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(cloudguest_http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Request Latency (p50 / p95 / p99)",
      "description": "histogram_quantile over cloudguest_http_request_duration_seconds_bucket -- PrometheusMiddleware (app.core.metrics) observes this Histogram inline, once per completed request.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(cloudguest_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p50 {{path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cloudguest_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(cloudguest_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Platform Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Health Check Status per Component",
      "description": "cloudguest_health_check_status: on-scrape Gauge, refreshed from app.domains.monitoring's ServiceHealth rollup table on every /metrics scrape. 1=healthy, 0=degraded, -1=unhealthy, -2=unknown.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Healthy", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "Degraded", "color": "orange" } } },
            { "type": "value", "options": { "-1": { "text": "Unhealthy", "color": "red" } } },
            { "type": "value", "options": { "-2": { "text": "Unknown", "color": "gray" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -0.5 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "cloudguest_health_check_status",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Alerts Triggered (all-time, by severity)",
      "description": "cloudguest_alerts_triggered_total: on-scrape Gauge, refreshed from app.domains.monitoring's Alert table (all-time COUNT(*) GROUP BY severity) on every /metrics scrape. Named with the conventional _total suffix; see app/core/metrics.py's module docstring for why this is a Gauge, not a Counter.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*critical.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*warning.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*info.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "cloudguest_alerts_triggered_total",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Guest & Provisioning",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Active Guest Sessions",
      "description": "cloudguest_guest_sessions_active: on-scrape Gauge, refreshed from app.domains.guest's GuestSession table (COUNT WHERE status='active') on every /metrics scrape.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "cloudguest_guest_sessions_active", "legendFormat": "active sessions", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Provisioning Jobs by Status",
      "description": "cloudguest_provisioning_jobs_total: on-scrape Gauge, refreshed from app.domains.router_provisioning's ProvisioningJob table (COUNT(*) GROUP BY status) on every /metrics scrape. A Gauge, not a Counter, because a job moving between statuses (e.g. queued -> running) makes one status's count go down.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*succeeded.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*running.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*queued.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "cloudguest_provisioning_jobs_total", "legendFormat": "{{status}}", "refId": "A" }
      ]
    }
  ]
}
